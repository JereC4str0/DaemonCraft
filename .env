# DaemonCraft — Low-resource optimization for WSL (3.7GB RAM)
# Bot server settings
API_PORT=3002
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=HermesBot
MC_AUTH=offline

# Disable heavy features to save RAM/CPU
DISABLE_PHOTO=true
DISABLE_VIEWER=true

# Puppeteer already skipped at install time via package.json
PUPPETEER_SKIP_DOWNLOAD=true
